# ============================================================================
# BandoFit — configurazione di deploy (docker compose)
# Copia questo file in `.env` accanto a docker-compose.yml e compila i valori.
# Il file .env NON va mai committato.
# ============================================================================

# --- Porte pubblicate sull'host ---
FRONTEND_PORT=3001
BACKEND_PORT=3002
# 127.0.0.1 = raggiungibili solo dal reverse proxy locale (consigliato).
# Mettere 0.0.0.0 per esporre direttamente le porte all'esterno (solo test).
BIND_ADDRESS=127.0.0.1

# --- Supabase PRIMARIO (piattaforma) ---
PRIMARY_SUPABASE_URL=
PRIMARY_SUPABASE_SERVICE_ROLE_KEY=
# Solo se il progetto usa ancora il legacy JWT secret HS256 (di norma vuoto)
PRIMARY_SUPABASE_JWT_SECRET=

# --- Supabase SECONDARIO (catalogo bandi, sola lettura) ---
SECONDARY_SUPABASE_URL=
SECONDARY_SUPABASE_ANON_KEY=

# --- URL pubblici ---
# Origine da cui il browser carica il frontend (per CORS), es. https://bandofit.example.com
CORS_ORIGINS=https://bandofit.example.com
# Stesso dominio: usato per i redirect degli inviti famiglia e i link nelle email
FRONTEND_URL=https://bandofit.example.com

# --- Email (Resend) ---
# Vuota = le email di invito vengono solo loggate nel container backend
RESEND_API_KEY=
EMAIL_FROM=BandoFit <onboarding@resend.dev>

# --- Frontend (variabili COTTE NEL BUNDLE al build: dopo averle cambiate
#     serve `docker compose up -d --build frontend`) ---
# Progetto Supabase PRIMARIO (solo autenticazione)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Come il BROWSER raggiunge il backend. Con il reverse proxy consigliato:
#   https://bandofit.example.com/api/v1
# Per una prova diretta senza proxy: http://IP-SERVER:3002/api/v1
VITE_API_BASE_URL=https://bandofit.example.com/api/v1
