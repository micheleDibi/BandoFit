# === DB primario (piattaforma BandoFit) ===
# URL del progetto Supabase primario, es. https://xxxx.supabase.co
PRIMARY_SUPABASE_URL=
# Chiave service_role del primario (SEGRETA: solo backend, mai nel frontend)
PRIMARY_SUPABASE_SERVICE_ROLE_KEY=
# JWT secret legacy (opzionale: serve solo se il progetto usa ancora HS256)
PRIMARY_SUPABASE_JWT_SECRET=

# === DB secondario (catalogo bandi, sola lettura) ===
SECONDARY_SUPABASE_URL=
SECONDARY_SUPABASE_ANON_KEY=

# === App ===
# Origini CORS separate da virgola
CORS_ORIGINS=http://localhost:5173
ENV=development
# URL pubblico del frontend (redirect inviti famiglia, link nelle email)
FRONTEND_URL=http://localhost:5173

# === Email ===
# Provider scelto automaticamente: SMTP se SMTP_HOST è valorizzato,
# altrimenti Resend se c'è la API key, altrimenti solo log (sviluppo).

# --- Opzione A: SMTP (es. casella OVH) ---
# OVH MX Plan: host ssl0.ovh.net, porta 465 (SSL) o 587 (STARTTLS)
SMTP_HOST=
SMTP_PORT=465
# Utente = indirizzo email completo della casella
SMTP_USER=
SMTP_PASSWORD=

# --- Opzione B: Resend (API HTTP) --- https://resend.com/api-keys
RESEND_API_KEY=

# Mittente delle email (con SMTP deve appartenere alla casella/dominio)
EMAIL_FROM=BandoFit <noreply@tuodominio.it>

# --- openapi.it (dati aziendali certificati e verifica CF) ---
# Credenziali da console.openapi.com (sezione chiavi API): le chiavi di
# sandbox e produzione sono DIVERSE e devono corrispondere a OPENAPI_ENV.
# Vuote = importazione disattivata. In sviluppo usare la sandbox (gratuita).
# Le API "Company" e "Risk" vanno attivate una tantum dalla Libreria API.
OPENAPI_EMAIL=
OPENAPI_API_KEY=
OPENAPI_ENV=sandbox
